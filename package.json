{
  "name": "octosift",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "octosift": "bun ./src/main.ts",
    "start": "bun ./src/main.ts",
    "dev": "bun --watch ./src/main.ts",
    "check": "bun run typecheck && bun run test",
    "qa": "bun run check",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  }
}
